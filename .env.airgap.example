# AgentLens — Air-gapped self-host configuration template.
# Copy to .env, set ADMIN_TOKEN, leave everything else as-is.
#
# This config makes ZERO outbound calls:
#   - No Anthropic judge calls (heuristic evaluation only)
#   - No Stripe / SendGrid / Resend
#   - No webhook calls outside localhost
#   - No telemetry of any kind

# REQUIRED: long random string used to bootstrap the first API key.
# Generate with:  openssl rand -hex 32
#                 — or — python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_TOKEN=CHANGE-ME-LONG-RANDOM-STRING

# Air-gap mode — disables every outbound integration regardless of other env vars.
AGENTLENS_AIRGAP=1

# Host port for the AgentLens dashboard / ingest API. Container internal port
# stays 8000 — this only changes the host-side mapping. Default 8000.
# If 8000 is occupied on your host, pick a free port:
#   sudo ss -ltn | awk 'NR>1 {sub(".*:","",$4); print $4}' | sort -un | \
#     awk 'BEGIN{p=8000} $1==p{p++} END{print p}'
# Then set: AGENTLENS_HOST_PORT=<the_port>
AGENTLENS_HOST_PORT=8000

# SQLite location inside the container (mapped to a named volume).
DATABASE_URL=sqlite+aiosqlite:////data/agentlens.db

# ── Everything below stays empty for air-gapped pilots ────────────────────────
# Re-enable individually only if you have an explicit reason.

# ANTHROPIC_API_KEY=        # leave empty → heuristic evaluation only
# JUDGE_SAMPLE_RATE=0.0
# JUDGE_DAILY_CAP=0

# Outbound notification channels — disabled in air-gap mode.
# SENDGRID_API_KEY=
# RESEND_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# DEMO_REQUEST_WEBHOOK_URL=
# SIGNUP_NOTIFY_WEBHOOK_URL=
# BILLING_EVENT_WEBHOOK_URL=
# INTERNAL_ALERT_WEBHOOK_URL=
# HEALTHCHECK_URL=
