# AgentLens - Local environment variables
# Copy this file to .env and fill in only the values you actually need locally.
# Production secrets belong in Railway env vars or GitHub Actions secrets, not in repo files.

# Core runtime
ADMIN_TOKEN=replace-with-long-random-admin-token
# DATABASE_URL=sqlite+aiosqlite:///./observability.db

# LLM / outbound messaging
ANTHROPIC_API_KEY=sk-ant-...
SENDGRID_API_KEY=SG....
SENDER_EMAIL=team@example.com

# Optional local automation
GITHUB_TOKEN=ghp_...
# STRIPE_SECRET_KEY=sk_test_...

# Demo request notifications
# DEMO_REQUEST_WEBHOOK_URL=https://hooks.slack.com/services/...
# RESEND_API_KEY=re_...
# DEMO_REQUEST_NOTIFY_EMAIL=ops@example.com
# DEMO_REQUEST_FROM_EMAIL=AgentLens <noreply@example.com>

# Ops / monitoring
# HEALTHCHECK_URL=https://www.agentlens.one/healthz
# INTERNAL_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
