# AgentLens — Local Environment Variables
# Kopiere diese Datei nach .env und trage deine echten Keys ein.
# .env wird NIE committet (steht in .gitignore).

# Claude API Key (Pflicht für LLM Judge + Outreach Agent)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# SendGrid API Key (für Outreach-Emails). Kostenlos bis 100 Emails/Tag.
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG....

# GitHub Personal Access Token (erhöht Rate Limit von 60/h auf 5000/h)
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Verifizierte Sender-Email in SendGrid (Single Sender Verification)
SENDER_EMAIL=deine-email@beispiel.de

# Stripe (nur lokal zum Testen — Production liegt in Railway Env Vars)
# STRIPE_SECRET_KEY=sk_test_...
