# Force LF for shell scripts and Dockerfile so Windows checkouts don't break
# the curl-pipe-bash install one-liner served by /install.
*.sh           text eol=lf
scripts/*      text eol=lf
Dockerfile     text eol=lf
docker-compose.yml text eol=lf
*.py           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
