# CRITICAL — customer-specific pilot artifacts contain personal data + sales
# strategy. Must NEVER be committed to a public repo. (GDPR + reputation risk.)
#
# The entire enterprise/ folder is INTERNAL — sales decks, pilot plans, AVV/DPA
# templates, security questionnaires, customer reply drafts. None of this
# belongs in a public commercial-license repo. Stays on local disk only.
enterprise/

# Pilot state config — contains contact_email and personal data of the active
# pilot customer. Cron jobs (pilot_pulse, etc.) read this locally; the example
# template (pilot_state.example.json) is the only version that ships in git.
agents/pilot_state.json

# Customer-specific scripts/tests — must not bake customer names into git.
scripts/build_*pilot*.py
scripts/build_*customer*.py
tests/test_*pilot*.py
tests/test_*customer*.py

# Audit + Radar reports — generated locally and by CI scans, not committed
.audit/

